{
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "FAMERS SIDE/**",
      "use": "@vercel/static"
    },
    {
      "src": "ADMIN SIDE/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/admin$",
      "dest": "/ADMIN SIDE/index.html"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/ADMIN SIDE/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/FAMERS SIDE/$1"
    }
  ]
}
