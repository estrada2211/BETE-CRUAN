{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/admin",
      "destination": "/ADMIN SIDE/index.html"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/ADMIN SIDE/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/FAMERS SIDE/$1"
    }
  ]
}
